# Ethereum RPC URL — use your own Alchemy/Infura key for production
# Default falls back to public demo endpoints (rate-limited)
NEXT_PUBLIC_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Etherscan API key — free tier sufficient
# Get one at https://etherscan.io/apis
NEXT_PUBLIC_ETHERSCAN_API_KEY=YOUR_ETHERSCAN_KEY
